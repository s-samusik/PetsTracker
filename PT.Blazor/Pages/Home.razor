@using PT.Blazor.Components.Home
@using PT.Blazor.Components.Layout

@page "/"
@layout LandingLayout

<MudContainer Class="pa-0">
    <MudPaper Class="pa-4"
              Style="width:100%; max-width:1200px; margin:auto; background-color:var(--color-light);">

        <MudGrid>
            <MudItem xs="12">
                <MudStack AlignItems="AlignItems.Center">
                    <MudImage Src="/img/pets.png"
                              Alt="Pets illustration"
                              Style="width:100%; border-radius:12px;" />

                    <MudText Typo="Typo.h5" Align="Align.Center" Style="color:var(--color-primary-dark);">
                        My Pets
                    </MudText>
                    <MudText Typo="Typo.h6" Align="Align.Center" Style="color:var(--color-primary-dark);">
                        просто &#8729; надежно &#8729; быстро
                    </MudText>
                    <MudText Typo="Typo.h6" Align="Align.Center" Style="color:var(--color-primary-dark);">
                        Мы поможем Вашему питомцу вернуться домой
                    </MudText>
                </MudStack>
            </MudItem>

            <MudItem xs="12" md="6"><DescriptionSection /></MudItem>
            <MudItem xs="12" md="6"><RegistrationSection /></MudItem>
            <MudItem xs="12" md="6"><QASection /></MudItem>
            <MudItem xs="12" md="6"><NewsSection /></MudItem>
        </MudGrid>
    </MudPaper>
</MudContainer>
