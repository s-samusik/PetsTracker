<MudStack Spacing="2"
          AlignItems="AlignItems.Center"
          Class="pa-2"
          Style="height: 90dvh">
    <MudIcon Class="mt-6"
             Style="font-size: 6rem;"
             Icon="@Icons.Material.Filled.ErrorOutline"
             Color="Color.Error" />

    <MudText Typo="Typo.h6" Align="Align.Center" Class="mt-4">
        К сожалению QR код не распознан
    </MudText>
    <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-4 mb-8">
        Отсканируйте, пожалуйста, его еще раз<br />или введите этот код в поле ниже,<br />и нажмите продолжить.
    </MudText>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="8">
            <MudTextField ShrinkLabel
                          @bind-Value="manualCode"
                          Label="QR Код"
                          Variant="Variant.Outlined"
                          T="string"
                          MaxLength="7"
                          Typo="Typo.button"
                          HelperText="Код указан на карточке под изображением QR,формат: АА11ААА"
                          Mask="@(new PatternMask("aa00aaa"))" />
        </MudItem>
    </MudGrid>

    <MudSpacer />

    <MudButton Variant="Variant.Outlined"
               Color="Color.Tertiary"
               FullWidth="true"
               OnClick="GoToRegistration">
        Продолжить
    </MudButton>
    <MudButton Variant="Variant.Text"
               Color="Color.Default"
               FullWidth="true"
               OnClick="GoHome">
        На главную
    </MudButton>
</MudStack>