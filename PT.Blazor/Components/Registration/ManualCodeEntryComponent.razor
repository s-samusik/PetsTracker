@using MudBlazor.Utilities
<MudStack AlignItems="AlignItems.Center"
          Style="height:100%; overflow-y:auto; overflow-x: hidden">
    <MudIcon Class="mt-6"
             Style="font-size: 6rem;"
             Icon="@Icons.Material.Filled.ErrorOutline"
             Color="Color.Error" />

    <MudText Typo="Typo.h6" Align="Align.Center" Class="mt-4">
        К сожалению QR код не распознан
    </MudText>
    <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-4 mb-8" Style="color:var(--color-primary-dark)">
        Ничего страшного.<br />
        Пожалуйста, отсканируйте код снова<br />
        или введите вручную ниже<br />
        и нажмите продолжить
    </MudText>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="6" sm="4">
            <MudTextField @bind-Value="manualCode"
                          Variant="Variant.Text"
                          Typo="Typo.h6"
                          MaxLength="7"
                          Class="@CodeInputClass"
                          Style="--mud-palette-primary: var(--color-primary-dark);"
                          HelperText="формат: AA11AAA"/>
        </MudItem>
    </MudGrid>

    <MudSpacer />

    <MudButton Variant="Variant.Filled"
               Style="width:90%; background-color:var(--color-primary-light); color:var(--color-light); flex-shrink:0; border-radius:25px;"
               OnClick="GoToRegistration">
        Продолжить
    </MudButton>
    <MudButton Variant="Variant.Text"
               Style="width:90%; color:var(--color-secondary); flex-shrink:0; border-radius:25px;"
               OnClick="GoHome">
        На главную
    </MudButton>
</MudStack>

@code {
    private string CodeInputClass => new CssBuilder("code-input").Build();
}