<MudStack Spacing="2"
          AlignItems="AlignItems.Center"
          Class="pa-2"
          Style="height: 100%">
    <MudIcon Class="mt-6"
             Style="font-size: 6rem;"
             Icon="@Icons.Material.Filled.ErrorOutline"
             Color="Color.Error" />

    <MudText Typo="Typo.h6" Align="Align.Center" Class="mt-4">
        К сожалению QR код не распознан
    </MudText>
    <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-4 mb-8">
        Отсканируйте, пожалуйста, его еще раз<br />или введите этот код в поле ниже,<br />и нажмите продолжить.
    </MudText>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="6" sm="4">
            <MudTextField @bind-Value="manualCode"
                          Variant="Variant.Text"
                          Margin="Margin.Dense"
                          T="string"
                          Typo="Typo.h6"
                          HelperText="формат: AA-11-AAA"
                          Mask="@QrCodeMask" />
        </MudItem>
    </MudGrid>

    <MudSpacer />

    <MudButton Variant="Variant.Outlined"
               Color="Color.Tertiary"
               FullWidth="true"
               OnClick="GoToRegistration">
        Продолжить
    </MudButton>
    <MudButton Variant="Variant.Text"
               Color="Color.Default"
               FullWidth="true"
               OnClick="GoHome">
        На главную
    </MudButton>
</MudStack>