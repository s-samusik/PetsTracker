<MudStack Spacing="2"
          AlignItems="AlignItems.Center"
          Class="pa-2"
          Style="height: auto; min-height:100%">

    <MudText Typo="Typo.h6" Align="Align.Center">
        Владелец
    </MudText>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="11" sm="9">
            <MudText Typo="Typo.body1" Align="Align.Center" Class="my-4">
                Укажите, пожалуйста,<br />
                номер телефона для связи
            </MudText>
            <MudTextField @bind-Value="PetCardModel.PhoneNumber"
                          Mask="@(new PatternMask("+000 (00) 000-00-00"))"
                          HelperText="формат: +375 (XX) XXX-XX-XX"
                          Variant="Variant.Text"
                          Margin="Margin.Dense"
                          Required
                          RequiredError="обязательное поле"
                          T="string"
                          Clearable />
        </MudItem>
    </MudGrid>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="11" sm="9">
            <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-6">
                Социальные сети, если нужно
            </MudText>
        </MudItem>
        <MudItem xs="11" sm="9">
            <MudSelect T="string"
                       SelectedValues="PetCardModel.SelectedSocials"
                       FullWidth
                       SelectedValuesChanged="OnSelectedSocialsChanged"
                       MultiSelection="true">
                <MudSelectItem Value="@("Instagram")">Instagram</MudSelectItem>
                <MudSelectItem Value="@("Telegram")">Telegram</MudSelectItem>
                <MudSelectItem Value="@("Viber")">Viber</MudSelectItem>
                <MudSelectItem Value="@("TikTok")">TikTok</MudSelectItem>
            </MudSelect>
            <br />
            @foreach (var social in PetCardModel.SelectedSocials)
            {
                <MudTextField @bind-Value="PetCardModel.SocialLinks[social]"
                              Variant="Variant.Text"
                              FullWidth
                              Counter="30"
                              MaxLength="30"
                              Immediate="true"
                              Adornment="Adornment.Start"
                              AdornmentColor="Color.Info"
                              AdornmentIcon="@GetSocialIcon(social)"
                              Class="mb-2" />
            }
        </MudItem>
    </MudGrid>
</MudStack>
