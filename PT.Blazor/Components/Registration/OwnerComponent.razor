<MudStack Spacing="2"
          AlignItems="AlignItems.Center"
          Class="pa-1"
          Style="height: auto; min-height:100%; overflow-y: auto; overflow-x: hidden">

    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" sm="9">
            <MudTextField @bind-Value="PetCardModel.PhoneNumber"
                          Mask="@(new PatternMask("+000 (00) 000-00-00"))"
                          HelperText="формат: +375 (XX) XXX-XX-XX"
                          Variant="Variant.Text"
                          FullWidth
                          Required
                          Label="ваш контактный номер"
                          RequiredError="обязательное поле"
                          T="string"
                          Clearable />
        </MudItem>
    </MudGrid>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" sm="9">
            <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-4" Style="color:#4CAF50">
                Также можно добавить соцсети.<br />
                Так тому, кто найдет вашего питомца,<br />
                будет проще с вами связаться<br />
                (прислать вам фото или видео)
            </MudText>
        </MudItem>
        <MudItem xs="12" sm="9">
            <MudSelect T="string"
                       SelectedValues="PetCardModel.SelectedSocials"
                       FullWidth
                       Dense="true"
                       Variant="Variant.Text"
                       Placeholder="выберите соцсеть"
                       SelectedValuesChanged="OnSelectedSocialsChanged"
                       MultiSelection="true">
                <MudSelectItem Value="@("Instagram")">Instagram</MudSelectItem>
                <MudSelectItem Value="@("Telegram")">Telegram</MudSelectItem>
                <MudSelectItem Value="@("Viber")">Viber</MudSelectItem>
                <MudSelectItem Value="@("TikTok")">TikTok</MudSelectItem>
            </MudSelect>
            <br />
            @foreach (var social in PetCardModel.SelectedSocials)
            {
                <MudTextField @bind-Value="PetCardModel.SocialLinks[social]"
                              Variant="Variant.Text"
                              FullWidth
                              Counter="30"
                              MaxLength="30"
                              Immediate="true"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentColor="Color.Info"
                              AdornmentIcon="@GetSocialIcon(social)"
                              Class="mb-1" />
            }
        </MudItem>
    </MudGrid>
</MudStack>
