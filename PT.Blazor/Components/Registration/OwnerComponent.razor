<MudStack AlignItems="AlignItems.Center"
          Style="min-height:100%">

    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" sm="9" Class="my-4">
            <MudTextField @bind-Value="PetCardModel.PhoneNumber"
                          HelperText="формат: 375 XX XXX XX XX или 80XX XXX XX XX"
                          Variant="Variant.Text"
                          FullWidth
                          Required
                          MaxLength="20"
                          Immediate="true"
                          Placeholder="ваш контактный номер"
                          RequiredError="это обязательное поле"
                          InputMode="InputMode.numeric"
                          Type="InputType.Tel"
                          T="string" />
        </MudItem>
    </MudGrid>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" sm="9">
            <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-4" Style="color:var(--color-primary-dark)">
                Укажите Ваши соцсети для связи.<br />
                Так тому, кто найдет вашего питомца, будет проще с вами связаться<br />
                (например, прислать фото или видео)
            </MudText>
        </MudItem>
        <MudItem xs="12" sm="9">
            @foreach (var social in Socials)
            {
                <MudTextField @bind-Value="PetCardModel.SocialLinks[social]"
                              Variant="Variant.Text"
                              FullWidth
                              Immediate="true"
                              Adornment="Adornment.Start"
                              AdornmentColor="Color.Default"
                              AdornmentIcon="@GetSocialIcon(social)"
                              Placeholder="@social"
                              Class="my-6" />
            }
        </MudItem>
    </MudGrid>
</MudStack>
