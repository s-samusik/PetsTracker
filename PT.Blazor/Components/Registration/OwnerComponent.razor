<MudStack Spacing="2"
          AlignItems="AlignItems.Center"
          Class="pa-2"
          Style="height: 90dvh">

    <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-4">
        Владелец
    </MudText>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="12">
            <MudTextField ShrinkLabel
                          @bind-Value="phoneNumber"
                          Mask="@(new PatternMask("+000 (00) 000-00-00"))"
                          HelperText="Образец: +XXX (XX) XXX-XX-XX"
                          Label="Номер телефона"
                          Variant="Variant.Outlined"
                          Required
                          RequiredError="Обязательное поле"
                          T="string"
                          Clearable />
        </MudItem>
    </MudGrid>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="12">
            <MudTextField ShrinkLabel
                          @bind-Value="username"
                          Label="Имя"
                          Counter="30"
                          MaxLength="30"
                          Immediate="true"
                          Disabled="@isDisabled"
                          Variant="Variant.Outlined"
                          T="string"
                          Clearable />
        </MudItem>
    </MudGrid>

</MudStack>
