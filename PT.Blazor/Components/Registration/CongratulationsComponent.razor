<MudStack AlignItems="AlignItems.Center"
          Style="height: 100%; overflow-y: auto; overflow-x: hidden">
    <MudIcon Class="mt-4"
             Style="font-size: 6rem; color:var(--color-primary-light)"
             Icon="@Icons.Material.Filled.DoneAll"
             Color="Color.Inherit" />

    <MudText Typo="Typo.h6" Align="Align.Center" Class="mt-4" Style="color:var(--color-primary-light)">
        Поздравляем!
    </MudText>
    <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-2" Style="color:var(--color-primary-light)">
        Карточка вашего питомца успешно зарегистрирована.<br />
        Теперь она будет отображаться при сканировании QR‑кода.<br />
        <br />
        Нажмите "Показать карточку" ниже<br />
        или просто отсканируйте код еще раз
    </MudText>

    <MudSpacer />

    <MudButton Variant="Variant.Filled"
               Style="width:90%; background-color:var(--color-primary-light); color:var(--color-light); flex-shrink:0; border-radius:25px;"
               OnClick="GoToCard">
        Показать карточку
    </MudButton>
    <MudButton Variant="Variant.Text"
               Style="width:90%; color:var(--color-secondary); flex-shrink:0"
               OnClick="GoHome">
        На главную
    </MudButton>
</MudStack>