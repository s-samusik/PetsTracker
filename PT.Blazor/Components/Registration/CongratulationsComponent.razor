<MudStack Spacing="2" 
          AlignItems="AlignItems.Center"
          Class="pa-1"
          Style="height: 100%; overflow-y: auto; overflow-x: hidden">
    <MudIcon Class="mt-6"
             Style="font-size: 6rem; color:#4CAF50"
             Icon="@Icons.Material.Filled.DoneAll" 
             Color="Color.Inherit" />

    <MudText Typo="Typo.h5" Align="Align.Center" Class="mt-4" Style="color:#4CAF50">
        Поздравляем!
    </MudText>
    <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-2" Style="color:#4CAF50">
        Карточка вашего питомца успешно зарегистрирована.<br />
        Теперь она будет отображаться при сканировании QR‑кода.<br />
        <br />
        Нажмите "Показать карточку" ниже<br />
        или просто отсканируйте код еще раз
    </MudText>

    <MudSpacer />

    <MudButton Variant="Variant.Outlined"
               Style="color:#4CAF50; background-color:white; border-color:#4CAF50; flex-shrink:0"
               FullWidth="true"
               OnClick="GoToCard">
        Показать карточку
    </MudButton>
    <MudButton Variant="Variant.Text"
               Style="color:#757575; flex-shrink:0"
               FullWidth="true"
               OnClick="GoHome">
        На главную
    </MudButton>
</MudStack>