<MudStack Spacing="2" 
          AlignItems="AlignItems.Center"
          Class="pa-2"
          Style="height: 100%">
    <MudIcon Class="mt-6"
             Style="font-size: 6rem;"
             Icon="@Icons.Material.Filled.DoneAll" 
             Color="Color.Success" />

    <MudText Typo="Typo.h5" Align="Align.Center" Class="mt-4">
        Поздравляем!
    </MudText>
    <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-2">
        Карточка вашего питомца успешно зарегистрирована.<br />
        Теперь она будет отображаться при сканировании QR‑кода.<br />
        <br />
        Можете попробовать,<br />
        нажмите "Показать карточку" ниже<br />
        или просто отсканируйте QR‑код еще раз
    </MudText>

    <MudSpacer />

    <MudButton Variant="Variant.Outlined"
               Color="Color.Tertiary"
               FullWidth="true"
               OnClick="GoToCard">
        Показать карточку
    </MudButton>
    <MudButton Variant="Variant.Text"
               Color="Color.Default"
               FullWidth="true"
               OnClick="GoHome">
        На главную
    </MudButton>
</MudStack>