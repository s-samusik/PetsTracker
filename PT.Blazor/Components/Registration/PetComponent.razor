<MudStack Spacing="2"
          AlignItems="AlignItems.Center"
          Class="pa-2"
          Style="height: 100%; display:flex; flex-direction:column;">

    <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-4">
        Питомец
    </MudText>

    <MudGrid>
        <MudItem xs="12" Class="d-flex justify-center">
            <MudAvatar Style="height:120px; width:120px; background-color:#f0f0f0">
                @if (string.IsNullOrWhiteSpace(PetCardModel.AvatarPreview))
                {
                    <MudIcon Icon="@Icons.Material.Filled.Pets"
                             Style="font-size: 6rem;"
                             Color="Color.Tertiary" />
                }
                else
                {
                    <MudImage Src="@PetCardModel.AvatarPreview"
                              Style="height:100%; width:100%; object-fit:cover;" />
                }
            </MudAvatar>
        </MudItem>
        <MudItem xs="12" Class="d-flex justify-center">
            <MudFileUpload @bind-Files="PetCardModel.Avatar"
                           OnFilesChanged="@SwapPicture"
                           Accept="image/*"
                           MaxFiles="1"
                           Clearable="true">
                <CustomContent>
                    <MudIconButton Color="Color.Info"
                                   OnClick="@context.OpenFilePickerAsync"
                                   Icon="@Icons.Material.Filled.PhotoCamera">
                    </MudIconButton>
                </CustomContent>
                <SelectedTemplate />           
            </MudFileUpload>
        </MudItem>
    </MudGrid>
    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" sm="9">
            <MudTextField @bind-Value="PetCardModel.PetName"
                          Label="кличка"
                          Counter="30"
                          MaxLength="30"
                          Immediate="true"
                          Variant="Variant.Text"
                          T="string"
                          Clearable />
        </MudItem>
    </MudGrid>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" sm="9">
            <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-4">
                Добавьте адрес, где живет питомец
            </MudText>
            <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-4">
                (но это необязательно)
            </MudText>
        </MudItem>
    </MudGrid>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" sm="9">
            <MudTextField @bind-Value="PetCardModel.Address"
                          Label="адрес"
                          Counter="50"
                          MaxLength="50"
                          MaxLines="3"
                          Sizing="InputSizing.Auto"
                          Immediate="true"
                          Variant="Variant.Text"
                          T="string"
                          HelperText="город, улица, дом"
                          Clearable />
        </MudItem>
    </MudGrid>
</MudStack>