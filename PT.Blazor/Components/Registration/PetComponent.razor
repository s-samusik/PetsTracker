<MudStack Spacing="2"
          AlignItems="AlignItems.Center"
          Class="pa-2"
          Style="height: 90dvh">

    <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-4">
        Питомец
    </MudText>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="12">
            <MudTextField ShrinkLabel
                          @bind-Value="petname"
                          Label="Кличка"
                          Counter="30"
                          MaxLength="30"
                          Immediate="true"
                          Variant="Variant.Outlined"
                          T="string"
                          Clearable />
        </MudItem>
    </MudGrid>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="12">
            <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-4">
                Также ниже Вы можете добавить адрес,<br/> куда принести вашего питомца.
            </MudText>
            <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-2 mb-4">
                Но это необязательно
            </MudText>
        </MudItem>
    </MudGrid>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="12">
            <MudTextField ShrinkLabel
                          @bind-Value="city"
                          Label="Город"
                          Counter="30"
                          MaxLength="30"
                          Immediate="true"
                          Variant="Variant.Outlined"
                          T="string"
                          Clearable />
        </MudItem>
    </MudGrid>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="12">
            <MudTextField ShrinkLabel
                          @bind-Value="street"
                          Label="Улица, дом"
                          Counter="50"
                          MaxLength="50"
                          Immediate="true"
                          Variant="Variant.Outlined"
                          T="string"
                          Clearable />
        </MudItem>
    </MudGrid>

</MudStack>
