<MudStack AlignItems="AlignItems.Center"
          Style="min-height: 100%; display:flex; flex-direction:column;">
    <MudGrid>
        <MudItem xs="12" Class="d-flex justify-center">
            <div style="position:relative; display:inline-block; height:120px; width:120px;">
                @if (!string.IsNullOrWhiteSpace(PetCardModel.AvatarPreview))
                {
                    <MudAvatar Style="height:120px; width:120px; background-color:#f0f0f0">
                        <MudImage Src="@PetCardModel.AvatarPreview"
                                  Style="height:100%; width:100%; object-fit:cover;" />
                    </MudAvatar>

                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   Style="position:absolute; top:-8px; right:-8px; background:white; border-radius:50%;"
                                   OnClick="@RemoveAvatar" />
                }
                else
                {
                    <MudAvatar Style="height:120px; width:120px; background-color:#f0f0f0; display:flex; align-items:center; justify-content:center;">
                        <MudIcon Icon="@Icons.Material.Filled.Pets"
                                 Style="font-size:64px; color:var(--color-primary-light);" />
                    </MudAvatar>
                }
            </div>
        </MudItem>
        <MudItem xs="12" Class="d-flex justify-center">
            <MudFileUpload @bind-Files="PetCardModel.Avatar"
                           OnFilesChanged="@SwapPicture"
                           Accept="image/*"
                           MaxFiles="1">
                <CustomContent>
                    <MudFab Style="background-color:var(--color-primary-light); color:var(--color-light)"
                            Size="Size.Small"
                            StartIcon="@Icons.Material.Filled.PhotoCamera"
                            OnClick="@context.OpenFilePickerAsync" />
                </CustomContent>
                <SelectedTemplate />
            </MudFileUpload>
        </MudItem>
    </MudGrid>
    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" sm="9">
            <MudTextField @bind-Value="PetCardModel.PetName"
                          Placeholder="кличка"
                          Class="mb-10"
                          Immediate="true"
                          Variant="Variant.Text"
                          T="string"
                           />
            <MudTextField Placeholder="адрес проживания питомца"
                          Immediate="true"
                          Class="mb-10"
                          Variant="Variant.Text"
                          T="string"
                           />
            <MudTextField @bind-Value="PetCardModel.Address"
                          Placeholder="особые приметы, характер, здоровье, вознаграждение и т.п."
                          Lines="3"
                          Class="mb-10"
                          Sizing="InputSizing.Fixed"
                          Immediate="true"
                          Variant="Variant.Text"
                          T="string" />
        </MudItem>
    </MudGrid>
</MudStack>