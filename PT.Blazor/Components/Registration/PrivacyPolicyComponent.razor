<MudStack AlignItems="AlignItems.Center"
          Class="pa-1"
          Style="height:100%; overflow-y:auto; overflow-x: hidden">
    <MudIcon Class="mt-3"
             Style="font-size: 2rem; color:var(--color-secondary)"
             Icon="@Icons.Material.Filled.Assignment"
             Color="Color.Inherit" />

    <MudText Typo="Typo.h6" Align="Align.Center">
        Пользовательское соглашение
    </MudText>

    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" sm="9">
            <MudTextField Variant="Variant.Text"
                          Style="max-height:65%"
                          T="string"
                          Text="@text"
                          Lines="23"
                          ReadOnly="true" />
        </MudItem>
    </MudGrid>
    <MudSpacer />
    <MudButton Variant="Variant.Filled"
               Style="width:90%; background-color:var(--color-primary-light); color:var(--color-light); flex-shrink:0; border-radius:25px;"
               OnClick="GoToStart">
        Принимаю
    </MudButton>
    <MudButton Variant="Variant.Text"
               Style="width:90%; color:var(--color-secondary); flex-shrink:0"
               OnClick="GoHome">
        На главную
    </MudButton>
</MudStack>

