<MudStack AlignItems="AlignItems.Center"
          Class="pa-1"
          Style="height: 100%;">
    <MudIcon Class="mt-3"
             Style="font-size: 6rem; color:var(--color-primary-light)"
             Icon="@Icons.Material.Filled.Pets"
             Color="Color.Inherit" />

    <MudText Typo="Typo.h5" Align="Align.Center" Class="mt-4" Style="color:var(--color-primary-dark)">
        Привет!
    </MudText>
    <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-4" Style="color:var(--color-primary-dark)">
        Давайте создадим профиль<br />
        для вашего любимца.<br /><br />
        Это поможет ему быстрее вернуться домой,<br />
        если он вдруг потеряется.<br />
        Это займет всего пару минут. Начнем?
    </MudText>
    <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-6" Style="color:var(--color-primary-dark)">
        (если возникли вопросы,<br />
        вы всегда можете перейти На Главную<br />
        и найти там ответы)
    </MudText>
    <MudSpacer />

    <MudButton Variant="Variant.Filled"
               Style="width:90%; background-color:var(--color-primary-light); color:var(--color-light); flex-shrink:0; border-radius:25px;"
               OnClick="GoToRegister">
        Начнем
    </MudButton>
    <MudButton Variant="Variant.Text"
               Style="width:90%; color:var(--color-secondary); flex-shrink:0"           
               OnClick="GoHome">
        На главную
    </MudButton>
</MudStack>