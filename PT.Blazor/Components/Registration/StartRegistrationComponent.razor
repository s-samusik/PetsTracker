<MudStack Spacing="2"
          AlignItems="AlignItems.Center"
          Class="pa-2"
          Style="height: 90dvh">
    <MudIcon Class="mt-6"
             Style="font-size: 6rem;"
             Icon="@Icons.Material.Filled.Pets"
             Color="Color.Info" />

    <MudText Typo="Typo.h5" Align="Align.Center" Class="mt-4">
        Привет!
    </MudText>
    <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-4">
        Давайте зарегистрируем карточку для вашего питомца.<br />Это просто и быстро. Приступим?
    </MudText>

    <MudSpacer />

    <MudButton Variant="Variant.Outlined"
               Color="Color.Tertiary"
               FullWidth="true"
               OnClick="GoToRegister">
        Начнем
    </MudButton>
    <MudButton Variant="Variant.Text"
               Color="Color.Default"
               FullWidth="true"
               OnClick="GoHome">
        На главную
    </MudButton>
</MudStack>