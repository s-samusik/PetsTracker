@namespace PT.Blazor.Components.Home

<MudPaper Class="pa-4" Elevation="2" Style="border-radius:12px; height:100%; background-color:var(--color-primary-light)">

    <MudStack Spacing="2" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h6" Style="color:var(--color-light)">
            Как связаться с нами:
        </MudText>

        <MudStack Row="true" Spacing="8" AlignItems="AlignItems.Center">
            <MudIcon Style="color:var(--color-primary-dark)" Icon="@Icons.Material.Filled.Mail" Size="Size.Large" />
            <MudIcon Style="color:var(--color-primary-dark)" Icon="@Icons.Custom.Brands.Apple" Size="Size.Large" />
            <MudIcon Style="color:var(--color-primary-dark)" Icon="@Icons.Custom.Brands.Google" Size="Size.Large" />
            <MudIcon Style="color:var(--color-primary-dark)" Icon="@Icons.Custom.Brands.Instagram" Size="Size.Large" />
            <MudIcon Style="color:var(--color-primary-dark)" Icon="@Icons.Custom.Brands.TikTok" Size="Size.Large" />
        </MudStack>
    </MudStack>
    
    <MudStack Style="margin-top:50px;">
        <MudText Typo="Typo.body1" Style="color:var(--color-primary-dark); margin:auto">
            ООО "БелПолКард" | УНП 291338545
        </MudText>
        <MudText Typo="Typo.body2" Style="color:var(--color-primary-dark); margin:auto">
            224025 г.Брест, ул. Белорусская, 51А-1
        </MudText>
        <MudText Typo="Typo.body2" Style="color:var(--color-primary-dark); margin:auto">
            info@my-pets.by
        </MudText>
        <MudText Typo="Typo.subtitle2" Style="color:var(--color-primary-dark); margin:auto">
            ⓒ 2026 БелПолКард
        </MudText>
    </MudStack>
</MudPaper>
