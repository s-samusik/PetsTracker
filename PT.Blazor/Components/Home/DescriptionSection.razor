@namespace PT.Blazor.Components.Home

<MudPaper Class="pa-4" Elevation="2" Style="border-radius:12px; height:100%;">
    <MudStack>
        <MudIcon Icon="fa fa-search" Size="Size.Medium" Style="color:var(--color-primary-dark); margin:auto;" />

        <MudText Typo="Typo.h6" Style="color:var(--color-primary-dark); margin:auto;">
            Как это работает:
        </MudText>

        <MudText Typo="Typo.body1" Style="color:var(--color-dark);">
            Активируйте карточку<br />
            <MudText Typo="Typo.body2" Style="color:var(--color-secondary);">
                - просто отсканируйте QR код и заполните анкету питомца: фото, кличка, контакты для связи.
            </MudText>
            Надежно закрепите брелок на ошейнике Вашего питомца<br />
            <MudText Typo="Typo.body2" Style="color:var(--color-secondary);">
                - теперь Ваш питомец защищен 24/7.
            </MudText>
            Готово! Мгновенная помощь
            <MudText Typo="Typo.body2" Style="color:var(--color-secondary);">
                - нашедшему не нужно ничего скачивать, он просто сканирует QR код - и вся информация для связи с Вами сразу видна на экране.
            </MudText>
        </MudText>
    </MudStack>
</MudPaper>