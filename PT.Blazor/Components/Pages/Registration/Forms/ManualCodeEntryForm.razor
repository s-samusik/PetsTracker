<MudStack Spacing="2"
          AlignItems="AlignItems.Center"
          Class="pa-2"
          Style="height: 90dvh">
    <MudIcon Class="mt-6"
             Style="font-size: 6rem;"
             Icon="@Icons.Material.Filled.ErrorOutline"
             Color="Color.Error" />

    <MudText Typo="Typo.h6" Align="Align.Center" Class="mt-4">
        К сожалению QR код
    </MudText>
    <MudText Typo="Typo.h4" Align="Align.Center">@Code</MudText>
    <MudText Typo="Typo.h6" Align="Align.Center">
        не распознан
    </MudText>
    <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-4">
        Код указан на карточке под изображением QR
    </MudText>
    <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-8">
        Введите, пожалуйста, этот код в поле ниже и нажмите продолжить
    </MudText>

    <MudTextField ShrinkLabel
                  @bind-Value="manualCode"
                  Label="QR Код"
                  Variant="Variant.Outlined"
                  T="string"
                  MaxLength="7"                 
                  Typo="Typo.h5"
                  Mask="@(new PatternMask("aa-00-aaa"))" />

    <MudSpacer />

    <MudButton Variant="Variant.Outlined"
               Color="Color.Tertiary"
               FullWidth="true"
               OnClick="GoToRegistration">
        Продолжить
    </MudButton>
    <MudButton Variant="Variant.Text"
               Color="Color.Default"
               FullWidth="true"
               OnClick="GoHome">
        На главную
    </MudButton>
</MudStack>