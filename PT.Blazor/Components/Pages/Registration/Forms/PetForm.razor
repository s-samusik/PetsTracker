@using Microsoft.AspNetCore.Components.Forms

<MudForm>

    <MudTextField Label="Кличка"
                  @bind-Value="Model.Nickname"
                  Required="true"
                  For="@(() => Model.Nickname)" />

    <MudTextField Label="Адрес"
                  @bind-Value="Model.Address"
                  For="@(() => Model.Address)" />

    <MudText Typo="Typo.h6" Class="mt-4">Фото питомца</MudText>

    <MudFileUpload T="IBrowserFile"
                   MaxFiles="1"
                   MaxFileSize="5000000"
                   Color="Color.Primary"
                   Variant="Variant.Outlined"
                   ButtonText="Загрузить фото" />

    @if (isLoadingPhoto)
    {
        <MudSkeleton Width="150px"
                     Height="150px"
                     Animation="Animation.Wave"
                     Class="mt-3" />
    }
    else if (!string.IsNullOrEmpty(Model.PhotoUrl))
    {
        <MudAvatar Size="Size.Large"
                   Image="@Model.PhotoUrl"
                   Class="mt-3" />
    }

    <MudText Typo="Typo.subtitle1" Class="mt-4">Или выберите аватар:</MudText>

    <MudStack Row="true" Spacing="2" Class="mt-2">
        @foreach (var avatar in DefaultAvatars)
        {
            <MudAvatar Size="Size.Large"
                       Image="@avatar"
                       Class="cursor-pointer"
                       @onclick="() => SelectAvatar(avatar)" />
        }
    </MudStack>

</MudForm>
